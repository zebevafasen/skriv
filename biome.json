{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "files": {
    "includes": [
      "**",
      "!!**/node_modules",
      "!!**/dist",
      "!!**/coverage",
      "!!**/.turbo",
      "!!**/.rustup",
      "!!**/.cargo",
      "!!**/.tmp",
      "!!**/target",
      "!!**/.vercel",
      "!!**/.vercel-build",
      "!!**/test-results",
      "!!covers-preview.html",
      "!!apps/desktop/src-tauri/gen",
      "!!apps/desktop/src-tauri/icons"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  }
}
