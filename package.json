{
  "name": "asterism",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "turbo build",
    "build:vercel": "pnpm --filter @asterism/db exec drizzle-kit push --force && node scripts/build-vercel-api.mjs && pnpm --filter @asterism/web build",
    "dev": "turbo dev --parallel",
    "typecheck": "turbo typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "infra:up": "docker compose up -d postgres",
    "infra:down": "docker compose down",
    "db:generate": "pnpm --filter @asterism/db db:generate",
    "db:migrate": "pnpm --filter @asterism/db db:migrate",
    "db:push": "pnpm --filter @asterism/db db:push"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "esbuild": "0.28.1",
    "turbo": "2.10.4",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
